{
  "name": "jet",
  "version": "0.0.0",
  "private": true,
  "description": "JET — AI-powered tools to launch and run a digital business",
  "scripts": {
    "dev": "pnpm --filter @jet/commerce dev",
    "build": "pnpm --filter @jet/commerce build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "pnpm --filter @jet/commerce exec prisma db push",
    "db:studio": "pnpm --filter @jet/commerce exec prisma studio",
    "db:seed": "pnpm --filter @jet/commerce exec tsx prisma/seed.ts"
  }
}
